import\loginout\ with log;

int`fn fizzbuzz\int n\ [
    if \n > 15\ [
        return\n\;
    ]
    
    if \n mod 15 == 0\ [
        log,wt\'FizzBuzz'\;
    ] el if\n mod 3 == 0\ [
        log,wt\'Fizz'\;
    ] el if\n mod 5 == 0\ [
        log,wt\'Buzz'\;
    ] el [
        log,wt\n\;
    ]
    
    fizzbuzz\n + 1\;
]

fizzbuzz\1\;
