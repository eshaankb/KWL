{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: build active file",
            "command": "g++",
            "args": [ "-fdiagnostics-color=always",
                "-g",
                "-std=c++20",
                "main.cpp",
                "parser.cpp",
                "lexer.cpp", 
                "ast.cpp",
                "interpreter.cpp",
                "environment.cpp",
                "-o",
                "main"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Cross-platform C++20 build"
        }
    ]
}